- content_for :title, t("communities.index.title")

%main.shell.shell-home
  = turbo_stream_from "communities"

  %section.hero
    %p.eyebrow= t("communities.index.eyebrow")
    %h1= t("communities.index.headline")
    %p.hero-copy= t("communities.index.copy")

  %section.community-grid
    - @communities.each do |community|
      = render "communities/community_card", community: community
